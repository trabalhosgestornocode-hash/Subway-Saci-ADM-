# =====================================================================
# Credenciais do Supabase DE TESTE para o teste de isolamento multi-tenant.
# Copie para .env.test e preencha. O .env.test NUNCA vai pro git (.gitignore).
#
# ⚠️  USE UM PROJETO SUPABASE DEDICADO A TESTES — NUNCA o de produção.
#     O teste cria e apaga organizações/usuários/dados a cada execução.
#
# Pré-requisito: aplique no projeto de teste o database/schema.sql +
# as migrations 001..017 (RLS por vínculos, superadmin e Martin Brower).
#
# Rodar:  npm run test:isolation      -> isolamento geral (migrations 014-016)
#         npm run test:isolation:mb   -> isolamento Martin Brower (017)
#         npm run test:isolation:all  -> os dois
# =====================================================================

# Supabase de TESTE — Project Settings > API
# ATENÇÃO ao padrão novo de chaves do Supabase:
#   SERVICE_ROLE = a chave SECRETA  -> começa com sb_secret_...      (ignora RLS)
#   ANON         = a chave PÚBLICA   -> começa com sb_publishable_... (respeita RLS)
# É fácil trocá-las de lugar — o preflight do teste avisa se isso acontecer.
TEST_SUPABASE_URL=https://SEU-PROJETO-DE-TESTE.supabase.co
TEST_SUPABASE_SERVICE_ROLE_KEY=sb_secret_COLOQUE_A_SECRET_DO_PROJETO_DE_TESTE
TEST_SUPABASE_ANON_KEY=sb_publishable_COLOQUE_A_PUBLISHABLE_DO_PROJETO_DE_TESTE

# Confirmação obrigatória de que o alvo acima é DESCARTÁVEL (nunca produção).
# Sem isto = 1, o teste destrutivo é pulado por segurança.
ISOLATION_TEST_DISPOSABLE=1
