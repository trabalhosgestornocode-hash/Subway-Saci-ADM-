{
  "name": "subway-saci-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API do sistema de gestão Subway Saci",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "start": "node src/server.js",
    "test": "node --test test/",
    "test:isolation": "node --env-file-if-exists=.env.test --test test/isolamento-tenant.test.js",
    "test:isolation:mb": "node --env-file-if-exists=.env.test --test test/isolamento-martinbrower.test.js",
    "test:isolation:all": "node --env-file-if-exists=.env.test --test test/isolamento-tenant.test.js test/isolamento-martinbrower.test.js",
    "diagnosticar:chaves": "node --env-file-if-exists=.env.test scripts/diagnosticar-chaves.js"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pdf-parse": "^1.1.1",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  }
}
