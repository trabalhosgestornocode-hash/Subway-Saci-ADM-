# Copie para .env e preencha. O .env NUNCA vai pro git (já está no .gitignore).
# Em produção (Render), defina estas variáveis no painel de Environment, não em arquivo.
PORT=3001

# Supabase — Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque_a_chave_SECRETA_sb_secret_xxx
SUPABASE_ANON_KEY=coloque_a_chave_publica_sb_publishable_xxx

# IDs padrão (usados pelo script criar-admin.js) — vindos do seed
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
DEFAULT_UNIDADE_ID=00000000-0000-0000-0000-0000000000a1

# ---------------------------------------------------------------------------
# Segurança HTTP
# ---------------------------------------------------------------------------
# Em produção: NODE_ENV=production ativa trust proxy, log "combined" e oculta
# detalhe interno dos erros 5xx.
# NODE_ENV=production

# Origens permitidas no CORS, separadas por vírgula. VAZIO = só mesma origem
# (o backend serve o frontend), que é o comportamento mais restritivo.
# Preencha só se o frontend passar a rodar em outro host.
# CORS_ORIGINS=https://app.crescercomdelivery.com.br

# CSP: sobe em Report-Only por padrão (registra violação no console, não
# bloqueia). Ligue para 'true' SÓ depois de confirmar no navegador que o app e
# o iframe do portal Martin Brower carregam sem violação.
CSP_ENFORCE=false

# ---------------------------------------------------------------------------
# Integração Martin Brower
# ---------------------------------------------------------------------------
# Liga a sincronização automatizada (worker Playwright). MANTENHA false no
# serviço principal do Render Free: o Chromium consome ~500 MB e derruba a API.
# Com false, as rotas que recebem credenciais nem aceitam a requisição.
MB_PLAYWRIGHT_ENABLED=false

# --- só necessárias quando MB_PLAYWRIGHT_ENABLED=true (Fase 3) -------------
# URL do worker no Cloud Run. Com a flag ligada e SEM estas duas variáveis, o
# adapter não é registrado e as rotas seguem respondendo WORKER_DISABLED.
# MB_WORKER_URL=https://mb-worker-XXXXXX.a.run.app
#
# Segredo compartilhado do HMAC (mesmo valor no worker). NÃO é credencial da
# Martin Brower. Gere com: openssl rand -base64 48
# MB_WORKER_SECRET=o_MESMO_segredo_configurado_no_worker
#
# Teto de uma chamada ao worker, em ms (default 300000).
# MB_WORKER_TIMEOUT_MS=300000
#
# Pula a obtenção do ID token OIDC (metadata server do GCP). Use APENAS em
# desenvolvimento local, com o worker rodando em container na sua máquina.
# Em produção o token é o que satisfaz o IAM do Cloud Run.
# MB_WORKER_SKIP_OIDC=false
#
# NUNCA existirá aqui: usuário, senha, JWT ou cookie do portal Martin Brower.
# A política é "credenciais efêmeras, mantidas exclusivamente em memória e
# descartadas ao final de cada sincronização".
