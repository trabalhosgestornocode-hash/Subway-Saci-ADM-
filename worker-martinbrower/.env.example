# Worker Martin Brower — copie para .env (gitignored) para rodar local.
# Em produção, estas variáveis vêm do Cloud Run / Secret Manager.

# Porta HTTP. O Cloud Run injeta PORT automaticamente; 8080 é o padrão dele.
PORT=8080

# OBRIGATÓRIA. Segredo compartilhado do HMAC entre backend e worker.
# Mínimo 32 caracteres — o worker RECUSA subir com menos.
# Gere com:  openssl rand -base64 48
# Em produção vive no Secret Manager, NUNCA em arquivo nem no repositório.
# NÃO é credencial da Martin Brower.
MB_WORKER_SECRET=troque_por_um_segredo_aleatorio_de_pelo_menos_32_caracteres

# --- opcionais (os valores abaixo são os padrões) ------------------------

# TTL total da sessão remota, em ms (10 min).
MB_SESSION_TTL_MS=600000
# TTL enquanto espera o código 2FA, em ms (5 min).
MB_2FA_TTL_MS=300000
# TTL de inatividade fora do 2FA, em ms (3 min).
MB_IDLE_TTL_MS=180000
# Sessões simultâneas por instância. Mantenha 1 — o Cloud Run roda com
# concurrency=1 e um segundo Chromium estouraria a memória.
MB_MAX_SESSOES=1

# Teto de uma execução, em ms. Deve ser MENOR que o --timeout do Cloud Run,
# para o worker devolver erro tratado antes de o Google cortar a conexão.
MB_WORKER_TIMEOUT_MS=600000

# Tamanho máximo do corpo de uma requisição interna (entradas são pequenas).
MB_MAX_BODY_BYTES=65536
# Teto da resposta do portal — corta payload anômalo antes de estourar a RAM.
MB_MAX_CATALOG_BYTES=12582912

# --- TRAVA DE ACESSO AO PORTAL REAL -------------------------------------
# O worker RECUSA SUBIR se MB_PORTAL_URL apontar para um host da Martin Brower
# sem MB_ALLOW_REAL_PORTAL=true. É proposital: impede que um teste automatizado
# tente logar no portal de produção por acidente (já aconteceu uma vez).
#
# Em TESTE: aponte para um alvo local e deixe MB_ALLOW_REAL_PORTAL de fora.
MB_PORTAL_URL=http://host.docker.internal:9099/
# MB_ALLOW_REAL_PORTAL não definida = portal real bloqueado.
#
# Em uso REAL e acompanhado, as duas linhas viram:
#   MB_PORTAL_URL=https://portal.martinbrower.com.br/
#   MB_ALLOW_REAL_PORTAL=true
# Só aceita a string exata "true" — "1" ou "yes" não liberam.

# NUNCA existirá aqui: usuário, senha, JWT ou cookie da Martin Brower.
# A política é "credenciais efêmeras, apenas em memória, descartadas ao fim
# de cada sincronização".
